# Haus Smart Home - Environment Variables

# Anthropic API key for AI concierge (required for device chat)
ANTHROPIC_API_KEY=

# Server port (default: 8080)
PORT=8080

# Database path (default: haus.db)
DB_PATH=haus.db

# Google Nest / SDM API (for Nest cameras, thermostats, doorbells)
# Get these from https://console.nest.google.com/device-access
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
